# Visual Studio 2026 / Rider / VS Code
# -----------------------------------------------------------------------------
.vs/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.DotSettings.user
*.swp
*.swo

# -----------------------------------------------------------------------------
# .NET / MSBuild build outputs
# -----------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Ll]og/
[Ll]ogs/
[Pp]ublish/
PublishScripts/
artifacts/

# Build + test results
*.binlog
*.trx
*.coverage
*.coveragexml
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
coverage/
*.opencover.xml

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# Roslyn / Source generator caches
.roslyn/
*.sourcelink.json

# EF Core local design-time
*.mdf
*.ldf
*.ndf

# JetBrains ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Debugger / profilers
*.pdb
*.pgc
*.pgd
*.rsp
*.psess
*.vsp
*.vspx
*.sap

# ClickOnce / MSIX
*.appx
*.appxbundle
*.msix
*.msixbundle

