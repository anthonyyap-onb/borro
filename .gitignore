# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.pnpm-store/
.yarn/cache/
.yarn/install-state.gz

# Build output
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.turbo/
.vite/
.parcel-cache/

# TypeScript
*.tsbuildinfo

# Test / coverage
coverage/
.nyc_output/
*.lcov

# Caches
.eslintcache
.stylelintcache
.cache/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local artifacts
*.local

# Playwright / Cypress
playwright-report/
test-results/
cypress/videos/
cypress/screenshots/

